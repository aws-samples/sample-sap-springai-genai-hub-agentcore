# Copy this file to .env and fill in your values
# Usage: ./deploy/cloudformation/deploy.sh

# Required: SAP AI Core service key (full JSON)
AICORE_SERVICE_KEY={"serviceurls":{"AI_API_URL":"..."},"appname":"...","clientid":"...","clientsecret":"...","identityzone":"...","url":"..."}

# Required: SAP S/4HANA Public Cloud API key
SAP_S4HANA_PUBLIC_CLOUD_KEY=your-sap-s4hana-api-key

# Required: Product Catalog backend (deploy product-catalog-service first)
PRODUCT_CATALOG_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com/prod
PRODUCT_CATALOG_API_KEY=REPLACE_WITH_YOUR_SECURE_API_KEY

# Optional overrides (defaults shown)
# AWS_REGION=us-east-1
# PROJECT_NAME=sapaiagent-gateway
# IMAGE_TAG=latest
