# Copy this file to .env and fill in your values
# Usage: ./deploy/cloudformation/deploy.sh

# Required: API key that protects the product catalog endpoints
# Generate a secure random API key (e.g., using: openssl rand -base64 32)
PRODUCT_CATALOG_API_KEY=REPLACE_WITH_YOUR_SECURE_API_KEY

# Optional overrides (defaults shown)
# AWS_REGION=us-east-1
# PROJECT_NAME=product-catalog
