# Copy this file to .env and fill in your values
# Usage: cp .env.example .env  then load env vars before running ./mvnw spring-boot:run
#
# Load env vars (do NOT use "source .env" — bash cannot parse raw JSON braces):
#   while IFS= read -r line; do [[ "$line" =~ ^#.*$ || -z "$line" ]] && continue; export "$line"; done < .env
#
# Or simply export each variable manually:
#   export AICORE_SERVICE_KEY='<paste JSON here>'

# Required: SAP AI Core service key (full JSON, unquoted — do NOT wrap in single or double quotes)
# Obtain: https://help.sap.com/docs/sap-ai-core/sap-ai-core-service-guide/create-service-key
# IMPORTANT: paste the raw JSON directly after the = sign, no surrounding quotes:
AICORE_SERVICE_KEY={"clientid":"...","clientsecret":"...","url":"https://....authentication.hana.ondemand.com","serviceurls":{"AI_API_URL":"https://api.ai.prod...hana.ondemand.com"}}
