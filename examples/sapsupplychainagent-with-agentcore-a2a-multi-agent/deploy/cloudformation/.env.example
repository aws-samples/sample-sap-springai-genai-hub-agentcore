# Copy this file to .env and fill in your values
# Usage: ./deploy/cloudformation/deploy.sh

# Required: SAP AI Core service key (full JSON) — used by worker agents
AICORE_SERVICE_KEY={"serviceurls":{"AI_API_URL":"..."},"appname":"...","clientid":"...","clientsecret":"...","identityzone":"...","url":"..."}

# Required: SAP S/4HANA Public Cloud API key — used by SAP worker agents
SAP_S4HANA_PUBLIC_CLOUD_KEY=your-sap-s4hana-api-key

# Optional: AgentCore Gateway integration for MCP tools agent
# Requires the sapsupplychainagent-with-agentcore-gateway project to be deployed first.
# Get these values from the gateway project's deploy/cloudformation/.runtime-state.
# The mcp-tools-agent activates the product catalog connection automatically when these are set.
PRODUCTCATALOG_GATEWAY_URL=
PRODUCTCATALOG_GATEWAY_CLIENT_ID=
PRODUCTCATALOG_GATEWAY_CLIENT_SECRET=
PRODUCTCATALOG_GATEWAY_TOKEN_ENDPOINT=

# Optional overrides (defaults shown)
# AWS_REGION=us-east-1
# PROJECT_NAME=sap-a2a-multi-agent
# IMAGE_TAG=latest
