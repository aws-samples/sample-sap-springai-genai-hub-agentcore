# Copy this file to .env and fill in your values
# Usage: ./deploy/cloudformation/deploy.sh

# Required: SAP AI Core service key (full JSON)
AICORE_SERVICE_KEY={"serviceurls":{"AI_API_URL":"..."},"appname":"...","clientid":"...","clientsecret":"...","identityzone":"...","url":"..."}

# Required: SAP S/4HANA Public Cloud API key
SAP_S4HANA_PUBLIC_CLOUD_KEY=your-sap-s4hana-api-key

# Optional overrides (defaults shown)
# AWS_REGION=us-east-1
# PROJECT_NAME=sapaiagent-observability
# IMAGE_TAG=latest
